{
  "name": "@komaa/openclaw-msteams-bridge",
  "version": "0.2.5",
  "author": "Alaaeldin Elhenawy <alaamh@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/komaa-com/openclaw-msteams-bridge"
  },
  "homepage": "https://komaa-com.github.io/openclaw-msteams-bridge/",
  "bugs": {
    "url": "https://github.com/komaa-com/openclaw-msteams-bridge/issues"
  },
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "microsoft-teams",
    "voice",
    "cvi",
    "realtime",
    "komaa"
  ],
  "description": "Microsoft Teams Bridge for OpenClaw: turn a Teams call into a real two-way video conversation. The agent sees your camera and screen-share, talks in real time (speech-to-speech or streaming STT to agent to TTS), and appears as a lip-synced avatar. Vision, meeting recap, outbound call-backs, wake-phrase etiquette, HMAC-secured.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "docx": "^9.0.0",
    "jszip": "^3.10.1",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.10"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "openclaw": "2026.6.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@komaa/openclaw-msteams-bridge",
      "defaultChoice": "npm"
    },
    "compat": {
      "pluginApi": ">=2026.6.10",
      "minGatewayVersion": "2026.6.10"
    },
    "build": {
      "openclawVersion": "2026.6.10",
      "pluginSdkVersion": "2026.6.10"
    },
    "channel": {
      "id": "msteams-voice",
      "label": "Microsoft Teams Voice"
    },
    "channelEnvVars": {
      "msteams-voice": [
        "MSTEAMS_APP_ID",
        "MSTEAMS_APP_PASSWORD",
        "MSTEAMS_TENANT_ID"
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  }
}
