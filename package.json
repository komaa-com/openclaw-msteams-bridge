{
  "name": "@komaa/msteams-voice",
  "version": "0.1.4",
  "author": "alaamh <alaamh@outlook.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/komaa-com/openclaw-msteams-voice"
  },
  "homepage": "https://docs.komaa.com",
  "bugs": {
    "url": "https://github.com/komaa-com/openclaw-msteams-voice/issues"
  },
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "microsoft-teams",
    "voice",
    "cvi",
    "realtime",
    "komaa"
  ],
  "description": "Self-contained Microsoft Teams CVI realtime-voice plugin for OpenClaw. Builds on the public realtime-voice SDK + api.runtime — no voice-call fork, no vendored CallManager. Single openclaw plugins install.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "docx": "^9.0.0",
    "jszip": "^3.10.1",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.9"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "openclaw": "2026.6.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@komaa/msteams-voice",
      "defaultChoice": "npm"
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  }
}
